<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
         body{
    background-color: bisque;
 }
 

button{
    
    background-color: #d08c00;
    transition: 0.3s;

    width: 400px;
    border-radius: 12px;
    padding: 15px;

    display: flex; 
    justify-content: center; 
    align-items: center;

    position: fixed;

    
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    height: 100px;
    font-size: 100px;

}

button:hover{
    transform: scale(1.05);
}

    </style>
</head>
<body>
    
    <a href="/escolher">
       <button>Acolha</button>
       
    </a>

</body>
</html>
