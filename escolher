<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
<style>
    body{
    background-color: #ffecdd;
}

header {
    position: fixed;
    top: 0;
    width: 100%;
    background: #c88400;
    display: flex;
    align-items: center;
    padding: 15px;
    gap: 20px;
}

.logo {
    width: 50px;
    height: 50px;
    background: #e5d2c2;
    border-radius: 50%;
}

header h1 {
    margin: 0;
    font-weight: normal;
}

.animais {
    display: flex;
    gap: 16px;
    padding: 20px;
    flex-wrap: wrap;

    justify-content: center; 
    align-items: center;     

    min-height: 100vh;       
}

.card {
    width: 300px;
    background: white;
    border-radius: 12px;
    padding: 15px;
    text-align: center;
    align-items: center;
    display: flex; 
    justify-content: center; 
    height: 300px;
    
    

    display: flex;
    flex-direction: column;
    gap: 10px;

    box-shadow: 0px 4px 12px rgba(0,0,0,0.1);


    transition: 0.3s;
    
}

.card:hover {
    transform: scale(1.05);
}
</style></head>
<body>
   <header>
    <div class="logo"></div>
    <h1>Acolha</h1>
</header>
    <div class="animais">
        <div class="card">
        <img src="data:image/jpeg;base64," alt="">
        <h1>sabor tartaruga</h1>
        <a href="/tartaruga">
            <button>ver informações</button>
        </a>
</div>

    <div class="card">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQIjk8CLiubOUUoI8FFfImP1AmMfQOr-l3hfg&s" alt="">
        <h1>cachorro</h1>
        <a href="/cachorro">
            <button>ver informações</button>
        </a>
        </div>
   

    <div class="card">
        <img src="data:image/jpeg;base64," alt="">
        <h1>gato</h1>
        <a href="/gato">
            <button>ver informações</button>
        </a>
    </div>

 </div>
    
</body>
</html>
